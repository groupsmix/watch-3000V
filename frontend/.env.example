# ──────────────────────────────────────────────
# WristNerd — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# IMPORTANT: None of these use the NEXT_PUBLIC_ prefix,
# so they are NEVER exposed in the client-side JavaScript bundle.
# ──────────────────────────────────────────────

# JWT signing secret (use a long random string, e.g. `openssl rand -base64 48`)
JWT_SECRET=

# ── Admin credentials ──
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# ── Editor credentials (optional) ──
EDITOR_EMAIL=
EDITOR_PASSWORD=
EDITOR_NAME=Editor

# ── Viewer credentials (optional) ──
VIEWER_EMAIL=
VIEWER_PASSWORD=
VIEWER_NAME=Viewer

# ── Google Analytics (public, safe for NEXT_PUBLIC_) ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=
